rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, fullName, email, role, category, subCategory, aadharNumber, bankAccountNumber, ifscCode, age, riskScore, weeklyPremium, createdAt
    
    // Collection: policies
    // Fields: userId, status, startDate, endDate, premiumAmount, coverageAmount
    
    // Collection: claims
    // Fields: userId, policyId, triggerEvent, amount, status, timestamp, location
    
    // Collection: disruptions
    // Fields: type, severity, location, timestamp, affectedCount

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sreenandasai24@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'role']) &&
             data.uid is string &&
             data.fullName is string && data.fullName.size() < 100 &&
             data.email is string &&
             data.role in ['worker', 'admin'];
    }

    function isValidClaim(data) {
      return data.keys().hasAll(['userId', 'triggerEvent', 'amount', 'status', 'timestamp']) &&
             data.userId is string &&
             data.amount is number &&
             data.status in ['pending', 'processed', 'flagged'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /policies/{policyId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /claims/{claimId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidClaim(request.resource.data) && (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update: if isAdmin();
    }

    match /disruptions/{disruptionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /indices/{indexId} {
      // Allow any authenticated user to check if an index exists (for uniqueness validation)
      allow get: if isAuthenticated();
      // Allow user to create their own index
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      // Allow user to update their own index (if needed)
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
  }
}
